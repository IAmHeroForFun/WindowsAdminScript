<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OmviHub Cloud Software Deployer (WPF &amp; Winget Engine)" 
        Width="1150" Height="800" MinWidth="900" MinHeight="650"
        Background="#0F172A" WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow" ResizeMode="CanResizeWithGrip"
        FontFamily="Segoe UI">
    <Window.Resources>
        <!-- Modern Dark Theme Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="#334155"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.9"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Search TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ComboBox Style -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Foreground" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#334155"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Header -->
            <RowDefinition Height="Auto"/> <!-- Filter Toolbar -->
            <RowDefinition Height="*"/>    <!-- Main App Catalog Grid -->
            <RowDefinition Height="Auto"/> <!-- Bottom Status & Actions -->
        </Grid.RowDefinitions>

        <!-- ROW 0: Header Panel (Draggable with explicit Window Controls) -->
        <Border x:Name="HeaderPanel" Grid.Row="0" Background="#1E293B" BorderBrush="#38BDF8" BorderThickness="0,0,0,2" Padding="24,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <!-- Left Title & Subtitle -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="OmviHub Cloud Software Deployer" FontSize="24" FontWeight="Bold" Foreground="#38BDF8"/>
                    <TextBlock Text="Lightweight Ninite-Style Automated Windows Package Deployment Command Center" FontSize="13" Foreground="#94A3B8" Margin="0,4,0,0"/>
                </StackPanel>
                
                <!-- Right Side: Winget Status & Window Controls (Minimize, Maximize, Close) -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Winget Status Badge -->
                    <Border Background="#0F172A" BorderBrush="#334155" BorderThickness="1" CornerRadius="8" Padding="12,8" Margin="0,0,16,0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="ImgWingetStatus" Width="12" Height="12" Fill="#EAB308" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtWingetStatus" Text="Checking Winget..." Foreground="#F8FAFC" FontWeight="Bold" FontSize="13" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Dedicated Window Controls -->
                    <Button x:Name="BtnMinimize" Content="🗕" Width="38" Height="36" FontSize="15" FontWeight="Bold" Background="#334155" Foreground="#F8FAFC" ToolTip="Minimize" Margin="0,0,6,0"/>
                    <Button x:Name="BtnMaximize" Content="🗖" Width="38" Height="36" FontSize="15" FontWeight="Bold" Background="#334155" Foreground="#F8FAFC" ToolTip="Maximize / Restore" Margin="0,0,6,0"/>
                    <Button x:Name="BtnClose" Content="✕" Width="40" Height="36" FontSize="15" FontWeight="Bold" Background="#DC2626" Foreground="#FFFFFF" ToolTip="Close Deployer"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ROW 1: Filter Toolbar -->
        <Grid Grid.Row="1" Margin="24,16,24,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/> <!-- Search Box -->
                <ColumnDefinition Width="220"/> <!-- Category Filter -->
                <ColumnDefinition Width="*"/>   <!-- Spacer -->
                <ColumnDefinition Width="Auto"/> <!-- Select All -->
                <ColumnDefinition Width="Auto"/> <!-- Deselect All -->
                <ColumnDefinition Width="Auto"/> <!-- Refresh -->
            </Grid.ColumnDefinitions>

            <TextBox x:Name="TxtSearch" Grid.Column="0" FontSize="14" Tag="Search 100+ applications..." Height="40"/>
            <ComboBox x:Name="CmbCategory" Grid.Column="1" FontSize="13" Height="40" Margin="12,0,0,0"/>

            <Button x:Name="BtnSelectAll" Grid.Column="3" Content="Select All" Width="105" Height="40" Background="#0284C7" FontWeight="Bold" Margin="0,0,8,0"/>
            <Button x:Name="BtnDeselectAll" Grid.Column="4" Content="Deselect All" Width="105" Height="40" Background="#475569" FontWeight="Bold" Margin="0,0,8,0"/>
            <Button x:Name="BtnRefresh" Grid.Column="5" Content="🔄 Refresh" Width="105" Height="40" Background="#334155" FontWeight="Bold"/>
        </Grid>

        <!-- ROW 2: Main App Catalog ListView -->
        <ListView x:Name="LstApps" Grid.Row="2" Margin="24,8" Background="#1E293B" Foreground="#F8FAFC" BorderBrush="#334155" BorderThickness="1"
                  ScrollViewer.HorizontalScrollBarVisibility="Disabled" SelectionMode="Single">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Background" Value="#1E293B"/>
                    <Setter Property="Foreground" Value="#F8FAFC"/>
                    <Setter Property="Padding" Value="8,6"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Style.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="#2A3B52"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#334A6A"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="70" Header="Select">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="240" Header="Application Name">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center" FontSize="14"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="180" Header="Category">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#0F172A" CornerRadius="4" Padding="10,4" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Category}" Foreground="#38BDF8" FontSize="11" FontWeight="Bold"/>
                                </Border>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="160" Header="Status">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusColor}" FontWeight="Bold" VerticalAlignment="Center" FontSize="13"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                    <GridViewColumn Width="430" Header="Description">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Description}" Foreground="#94A3B8" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" FontSize="13"/>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ROW 3: Bottom Status & Activity Log -->
        <Border Grid.Row="3" Background="#1E293B" CornerRadius="12" Margin="24,8,24,24" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Progress Bar & Text -->
                    <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                    <RowDefinition Height="Auto"/> <!-- Activity Log -->
                </Grid.RowDefinitions>

                <!-- Status & Progress -->
                <Grid Grid.Row="0" Margin="0,0,0,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="TxtStatus" Grid.Row="0" Text="Ready to deploy applications." Foreground="#F8FAFC" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                    <ProgressBar x:Name="PrgDeploy" Grid.Row="1" Height="14" Foreground="#22C55E" Background="#0F172A" BorderBrush="#334155" BorderThickness="1" Value="0"/>
                </Grid>

                <!-- Action Buttons -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,14">
                    <Button x:Name="BtnInstall" Content="⚡ Install Selected Apps" Width="220" Height="44" Background="#16A34A" FontSize="15" FontWeight="Bold" Margin="0,0,12,0"/>
                    <Button x:Name="BtnUpdate" Content="🔄 Update Installed Apps" Width="220" Height="44" Background="#0284C7" FontSize="15" FontWeight="Bold"/>
                </StackPanel>

                <!-- Activity Log Textbox -->
                <TextBox x:Name="TxtLog" Grid.Row="2" Height="140" Background="#090D16" Foreground="#38BDF8" FontFamily="Consolas" FontSize="12" 
                         IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" Padding="10" BorderBrush="#334155"/>
            </Grid>
        </Border>
    </Grid>
</Window>
